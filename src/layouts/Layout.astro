---
import { siteConfig } from '../data/site';
import { locales, localizedPath } from '../data/i18n';
import CookieBanner from '../components/global/CookieBanner.astro';
// Las fuentes se cargan una sola vez desde el barrel global.css (wght.css).
import '../styles/global.css';

// woff2 latin del eje wght para precargarlos (Vite devuelve la URL final).
import jakartaWoff2 from '@fontsource-variable/plus-jakarta-sans/files/plus-jakarta-sans-latin-wght-normal.woff2?url';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import monoWoff2 from '@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  pageName: string;
  lang?: keyof typeof locales;
}

// El idioma llega por prop (no por params): así funciona igual en la raíz (es)
// que en /en, sin depender de un segmento dinámico de ruta.
const { title, description, pageName, lang = 'es' } = Astro.props;

const googleAnalyticsId = 'G-7XZMZNVW3L';
const googleAdsId = 'AW-18316357590';

const siteUrl = siteConfig.url;
const subpath = pageName === 'home' ? '' : pageName;
const canonicalUrl = `${siteUrl}${localizedPath(lang, subpath)}`;
const ogImageUrl = `${siteUrl}/images/og/${lang}/${pageName}.png`;

// hreflang: cada idioma es una URL real; se lo decimos a Google explícitamente.
const langCodes = Object.keys(locales) as (keyof typeof locales)[];
const alternates = langCodes.map((l) => ({
  hreflang: l === 'es' ? 'es-CO' : l,
  href: `${siteUrl}${localizedPath(l, subpath)}`,
}));
const ogLocale = lang === 'es' ? 'es_CO' : 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- 1. Metadatos Base -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Precarga de las fuentes del contenido visible (mejora LCP/CLS) -->
    <link rel="preload" href={jakartaWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={monoWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Alternativas por idioma (hreflang) para SEO multiidioma -->
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${localizedPath('es', subpath)}`} />

    <!-- 2. SEO General y Rastreo -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta name="robots" content="index, follow" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- 3. UX / UI Metadatos -->
    <meta name="theme-color" content="#0a1c2b" />

    <!-- 4. Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    <!-- 5. Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Política de Seguridad de Contenido (CSP) para mitigar XSS y Clickjacking -->
    <meta
      http-equiv="Content-Security-Policy"
      content="
        default-src 'self';

        script-src
          'self'
          'unsafe-inline'
          blob:
          https://www.googletagmanager.com
          https://googleads.g.doubleclick.net;

        connect-src
          'self'
          https://www.googletagmanager.com
          https://www.google-analytics.com
          https://region1.google-analytics.com
          https://region2.google-analytics.com
          https://analytics.google.com
          https://stats.g.doubleclick.net
          https://googleads.g.doubleclick.net
          https://ad.doubleclick.net
          https://www.googleadservices.com
          https://www.google.com
          https://pagead2.googlesyndication.com
          https://formspree.io;

        img-src
          'self'
          data:
          https://www.googletagmanager.com
          https://www.google-analytics.com
          https://stats.g.doubleclick.net
          https://googleads.g.doubleclick.net
          https://www.googleadservices.com
          https://www.google.com
          https://www.google.com.co
          https://pagead2.googlesyndication.com;

        style-src
          'self'
          'unsafe-inline';

        font-src
          'self'
          data:;

        frame-src
          'self'
          https://www.google.com;
      "
    />

    <!-- Google Consent Mode v2 — SIEMPRE primero, antes de cargar gtag.js.
         Por defecto TODO denegado: no se activan cookies de analítica ni de
         anuncios hasta que el usuario acepte en el banner. Si ya aceptó en una
         visita anterior, se reaplica de inmediato (preferencia guardada). -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      window.gtag = gtag;

      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        wait_for_update: 500,
      });

      try {
        if (localStorage.getItem("ctg-cookie-consent") === "granted") {
          gtag("consent", "update", {
            ad_storage: "granted",
            ad_user_data: "granted",
            ad_personalization: "granted",
            analytics_storage: "granted",
          });
        }
      } catch (e) {}
    </script>

    <!-- Google tag (gtag.js): la librería se carga DIFERIDA — en cuanto el
         navegador esté ocioso o a la primera interacción. Los comandos
         (js/config) se encolan de inmediato y gtag.js los procesa al cargar,
         respetando el consentimiento por defecto (denegado). -->
    {googleAnalyticsId && googleAdsId && (
      <script is:inline define:vars={{ googleAnalyticsId, googleAdsId }}>
        gtag("js", new Date());

        // Google Analytics
        gtag("config", googleAnalyticsId);

        // Google Ads
        gtag("config", googleAdsId);

        let gtagLoaded = false;

        function loadGtag() {
          if (gtagLoaded) return;
          gtagLoaded = true;

          const s = document.createElement("script");
          s.async = true;
          s.src = `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`;
          document.head.appendChild(s);
        }

        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadGtag, { timeout: 4000 });
        } else {
          setTimeout(loadGtag, 3000);
        }

        ["scroll", "pointerdown", "keydown", "touchstart"].forEach((ev) => {
          window.addEventListener(ev, loadGtag, {
            once: true,
            passive: true,
          });
        });
      </script>
    )}
  </head>
  <body>
    <slot />
    <CookieBanner lang={lang} />
  </body>
</html>

<style>
  /* NO usar height: 100% aquí: constriñe el <body> a la altura del viewport y
     rompe el position: sticky de la navbar (se despega tras la primera
     pantalla). El reset ya aplica width/min-height. */
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>
