---
/**
 * Sun — el sol del descenso, medido como con un sextante (escena de Projects ·
 * tono horizon).
 *
 * El sol baja con el scroll hasta ocultarse tras la línea del horizonte (el
 * corte duro del tono horizon en el 62% de la sección). Lo recubre un anillo
 * de sextante — órbita punteada, limbo graduado de 160° y el índice ámbar que
 * marca la lectura — que gira conforme cae: la
 * altura del astro se está midiendo. Bajo la línea, el agua devuelve el fuego
 * en una senda de reflejos que titila.
 *
 * Coreografía por PROGRESO PROPIO de la sección (no offsets absolutos): el JS
 * publica --sun (0 → 1) en la escena; el CSS lo traduce solo a transform y
 * opacity. Sin JS o con prefers-reduced-motion: postal estática con el sol
 * posado sobre el horizonte (--sun por defecto).
 *
 * Uso: hijo directo de una sección con position:relative (z-index 0,
 * aria-hidden).
 */
import "./Sun.css";
---

<div class="sunset" aria-hidden="true" data-sun-scene>
  <!-- El cielo: recorta al sol cuando cruza la línea del horizonte -->
  <div class="ss-sky">
    <div class="ss-sun">
      <span class="ss-halo"></span>
      <span class="ss-core"></span>

      <!-- El limbo del sextante: órbita punteada, arco graduado de 160° con
           las marcas hacia AFUERA (el disco queda limpio) y el índice ámbar
           que marca la lectura. Todo gira suavemente con la caída. -->
      <svg class="ss-ring" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg">
        <g class="ss-ring-rotor">
          <circle class="ss-ring-orbit" cx="110" cy="110" r="88" fill="none"
          ></circle>
          <path
            class="ss-ring-limb"
            d="M 23.34 94.72 A 88 88 0 0 1 196.66 94.72"
            fill="none"></path>
          <g class="ss-ring-ticks">
            {
              Array.from({ length: 21 }).map((_, i) => (
                <line
                  x1="110"
                  y1="22"
                  x2="110"
                  y2={i % 5 === 0 ? "10" : "16"}
                  transform={`rotate(${-80 + i * 8} 110 110)`}
                />
              ))
            }
          </g>
          <g class="ss-index">
            <line x1="110" y1="12" x2="110" y2="2"></line>
            <path d="M 110 14 L 114.5 23 L 110 32 L 105.5 23 Z"></path>
          </g>
        </g>
      </svg>
    </div>
  </div>

  <!-- La línea de fuego del horizonte y su calima -->
  <span class="ss-horizon"></span>
  <span class="ss-haze"></span>

  <!-- La senda del sol: el reflejo que titila sobre el agua -->
  <div class="ss-glitter">
    <span class="ss-glitter-layer ss-glitter-layer--a"></span>
    <span class="ss-glitter-layer ss-glitter-layer--b"></span>
  </div>
</div>

<script>
  /**
   * Publica --sun (0 → 1) según el progreso de la sección anfitriona por el
   * viewport, calculado sobre el progreso PROPIO (rect de la sección): el
   * contenido futuro de Projects podrá cambiar de altura sin desincronizar
   * la caída.
   *
   * El valor NO salta con la rueda del scroll: un bucle rAF interpola (lerp)
   * el valor actual hacia el objetivo — la caída es continua y sedosa aunque
   * el scroll llegue a trompicones. El bucle solo corre mientras la sección
   * anda cerca del viewport. Con reduced-motion no se toca nada (postal CSS).
   */
  const scenes = document.querySelectorAll<HTMLElement>("[data-sun-scene]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  scenes.forEach((scene) => {
    const section = scene.closest("section") ?? scene.parentElement;
    if (!section) return;

    let raf = 0;
    let inView = false;
    let current = -1; // sin medir aún: arranca en el objetivo, sin barrido

    const target = (): number => {
      const rect = section.getBoundingClientRect();
      const vh = window.innerHeight;
      const raw = (vh - rect.top) / (vh + rect.height);
      return Math.min(1, Math.max(0, raw));
    };

    const loop = () => {
      const t = target();
      if (current < 0) current = t;
      current += (t - current) * 0.075;
      if (Math.abs(t - current) < 0.0004) current = t;
      scene.style.setProperty("--sun", current.toFixed(4));
      raf = inView ? requestAnimationFrame(loop) : 0;
    };

    const start = () => {
      if (!raf && inView && !reduceMotion.matches) {
        raf = requestAnimationFrame(loop);
      }
    };
    const stop = () => {
      cancelAnimationFrame(raf);
      raf = 0;
    };

    /* El bucle vive solo con la sección cerca (margen generoso para que la
       caída ya venga andando cuando el sol asome). */
    const io = new IntersectionObserver(
      ([entry]) => {
        inView = entry.isIntersecting;
        if (inView) start();
      },
      { rootMargin: "40% 0px 40% 0px" },
    );
    io.observe(section);

    reduceMotion.addEventListener("change", (e) => {
      if (e.matches) {
        stop();
        scene.style.removeProperty("--sun"); // vuelve a la postal por defecto
      } else {
        current = -1;
        start();
      }
    });
  });
</script>
