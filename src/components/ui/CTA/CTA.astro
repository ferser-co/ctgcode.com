---
/**
 * CTA — el botón de acción de marca ("el faro del atardecer").
 *
 * Componente parametrizado pero de estilo fijo: siempre es EL CTA. Renderiza
 * <a> si recibe `href`, si no <button>. Tamaños: "md" (por defecto) y "sm"
 * (barras compactas como la navbar). El posicionamiento/visibilidad en cada
 * contexto es responsabilidad de quien lo usa (envolver, no re-estilar).
 *
 * Estilos co-ubicados en CTA.css.
 */
import "./CTA.css";

interface Props {
  href?: string;
  size?: "md" | "sm";
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const { href, size = "md", type, class: className, ...rest } = Astro.props;
const Tag = href ? "a" : "button";
const attrs = href ? { href } : { type: type ?? "button" };
---

<Tag
  class:list={["cta", `cta--${size}`, className]}
  draggable={false}
  {...attrs}
  {...rest}
>
  <span class="cta-label"><slot /></span>

  <!-- Filtro "aire caliente": ruido térmico que desplaza las letras al hover.
       Si hay varios CTA en la página el id se repite; url(#cta-heat) resuelve
       al primero y el efecto es idéntico para todos. -->
  <svg class="cta-defs" aria-hidden="true" focusable="false">
    <filter id="cta-heat" x="-25%" y="-40%" width="150%" height="180%">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.012 0.085"
        numOctaves="2"
        seed="7"
        result="noise"
      >
        <animate
          attributeName="baseFrequency"
          values="0.012 0.085; 0.017 0.1; 0.01 0.07; 0.012 0.085"
          dur="7s"
          repeatCount="indefinite"
        />
      </feTurbulence>
      <feDisplacementMap
        in="SourceGraphic"
        in2="noise"
        scale="3.2"
        xChannelSelector="R"
        yChannelSelector="G"
      />
      <feGaussianBlur stdDeviation="0.25" />
    </filter>
  </svg>
</Tag>
