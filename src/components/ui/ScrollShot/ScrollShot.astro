---
/**
 * ScrollShot — el sitio del cliente, recorrido sin salir del nuestro.
 *
 * Una captura de PÁGINA COMPLETA (muy alta) vive dentro de un marco de altura
 * fija: al avanzar el scroll por la sección anfitriona, la imagen se traslada
 * dentro del marco, de modo que al terminar la sección el visitante ya ha
 * recorrido el sitio entero. Enseña trabajo real en vez de una miniatura
 * muerta.
 *
 * Si se pasa `mobile`, el teléfono se superpone al marco de escritorio y
 * recorre su propia captura a OTRA velocidad: sincronizados se ven mecánicos,
 * desfasados se lee profundidad. En viewport estrecho solo se muestra la
 * captura móvil — un pantallazo de escritorio reducido no se lee.
 *
 * FORMATOS: cada captura llega en AVIF, WebP y PNG, y se sirven con <picture>
 * en cadena de respaldo. El navegador se queda con el primero que entienda:
 * AVIF (el más compacto) → WebP (soporte casi universal) → PNG (el último
 * recurso). Son ficheros ya optimizados a mano, así que se emiten tal cual
 * en vez de pasar por el transformador de Astro.
 *
 * El progreso se calcula por el avance PROPIO de la sección (mismo criterio
 * que el sol del descenso) e interpola por rAF, así el recorrido es sedoso
 * aunque el scroll llegue a saltos. Solo se anima `transform`.
 *
 * Con prefers-reduced-motion: postal estática — se ve la cabecera del sitio,
 * quieta. No se oculta nada.
 */
import "./ScrollShot.css";

/** Las tres versiones del mismo pantallazo, de la más moderna a la más compatible. */
export interface ShotSources {
  avif: ImageMetadata;
  webp: ImageMetadata;
  /** Además de ser el último respaldo, aporta las dimensiones reales. */
  png: ImageMetadata;
}

interface Props {
  desktop: ShotSources;
  mobile?: ShotSources;
  /** Describe el sitio capturado, no el componente. */
  alt: string;
  /** Lo que se muestra en la barra del navegador simulado. */
  url: string;
}

const { desktop, mobile, alt, url } = Astro.props;
---

<div class="shot" data-scroll-shot>
  <!-- Escritorio: la pieza principal -->
  <figure class="shot-frame shot-frame--desk">
    <div class="shot-chrome" aria-hidden="true">
      <span class="shot-dots"><i></i><i></i><i></i></span>
      <span class="shot-url">{url}</span>
    </div>

    <div class="shot-view">
      <picture>
        <source type="image/avif" srcset={desktop.avif.src} />
        <source type="image/webp" srcset={desktop.webp.src} />
        <img
          class="shot-img"
          src={desktop.png.src}
          width={desktop.png.width}
          height={desktop.png.height}
          alt={alt}
          loading="lazy"
          decoding="async"
        />
      </picture>
    </div>
  </figure>

  {
    mobile && (
      <figure class="shot-frame shot-frame--phone">
        <div class="shot-view">
          <picture>
            <source type="image/avif" srcset={mobile.avif.src} />
            <source type="image/webp" srcset={mobile.webp.src} />
            <img
              class="shot-img"
              src={mobile.png.src}
              width={mobile.png.width}
              height={mobile.png.height}
              alt={alt}
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
      </figure>
    )
  }
</div>

<script>
  /**
   * Publica `--shot` (0 → 1) según el avance de la sección anfitriona por el
   * viewport, interpolado por rAF para que el recorrido no vaya a tirones.
   * El bucle solo corre con la sección cerca. Con reduced-motion no se toca
   * nada: manda la postal estática del CSS.
   */
  const shots = document.querySelectorAll<HTMLElement>("[data-scroll-shot]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  shots.forEach((shot) => {
    let raf = 0;
    let inView = false;
    let current = -1; // sin medir aún: arranca en el objetivo, sin barrido

    /**
     * El recorrido se ata AL MARCO, no a la sección: vale 0 justo cuando el
     * marco asoma por abajo y 1 cuando acaba de salir por arriba. Atarlo a la
     * sección (que es mucho más alta y tiene el marco a media altura) hacía
     * que al llegar a verlo el progreso ya fuera por la mitad — y el visitante
     * se perdía la cabecera del sitio capturado, que es lo que más importa.
     */
    const target = (): number => {
      const rect = shot.getBoundingClientRect();
      const vh = window.innerHeight;
      const startAt = vh * 0.9; // rect.top en el instante en que empieza
      const span = vh * 0.8 + rect.height; // distancia total del recorrido
      const raw = (startAt - rect.top) / span;
      return Math.min(1, Math.max(0, raw));
    };

    const loop = () => {
      const t = target();
      if (current < 0) current = t;
      current += (t - current) * 0.08;
      if (Math.abs(t - current) < 0.0004) current = t;
      shot.style.setProperty("--shot", current.toFixed(4));
      raf = inView ? requestAnimationFrame(loop) : 0;
    };

    const start = () => {
      if (!raf && inView && !reduceMotion.matches) {
        raf = requestAnimationFrame(loop);
      }
    };
    const stop = () => {
      cancelAnimationFrame(raf);
      raf = 0;
    };

    const io = new IntersectionObserver(
      ([entry]) => {
        inView = entry.isIntersecting;
        if (inView) start();
      },
      { rootMargin: "30% 0px 30% 0px" },
    );
    io.observe(shot);

    reduceMotion.addEventListener("change", (e) => {
      if (e.matches) {
        stop();
        shot.style.removeProperty("--shot");
      } else {
        current = -1;
        start();
      }
    });
  });
</script>
