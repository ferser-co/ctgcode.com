---
import Layout from "../layouts/Layout.astro";
import RouterPage from "../components/ui/RouterPage.astro";
import { defaultLang } from "../data/i18n";
import Logo from "../assets/logo.svg?raw";

const lang = defaultLang;
const title = "CTG Code";

const subtitle =
  lang === "es" ? "Preparando tu experiencia" : "Preparing your experience";
const description =
  lang === "es"
    ? "Te estamos llevando al sitio correcto según tu idioma."
    : "We're taking you to the right place for your language.";
const actions: Array<{
  href: string;
  label: string;
  variant: "primary" | "secondary";
}> = [
  { href: "/es/", label: "Español", variant: "primary" },
  { href: "/en/", label: "English", variant: "secondary" },
];
const detected =
  (defaultLang as string) === "en" ? "Detected: English" : "Detectado: Español";
---

<Layout title={title} description={description} pageName="home">
  <RouterPage
    title={title}
    subtitle={subtitle}
    description={description}
    actions={actions}
    logoHtml={Logo}
    detected={detected}
  />

  <script is:inline>
    (function () {
      const preferred = navigator?.language ?? "";
      const browserLang = preferred.split(",")[0]?.split("-")[0] ?? "";
      const isEn = browserLang === "en";

      const subtitleEl = document.querySelector(".subtitle");
      const descriptionEl = document.querySelector(".description");
      const detectedEl = document.querySelector(".detected");

      if (subtitleEl)
        subtitleEl.textContent = isEn
          ? "Preparing your experience"
          : "Preparando tu experiencia";
      if (descriptionEl)
        descriptionEl.textContent = isEn
          ? "We're taking you to the right place for your language."
          : "Te estamos llevando al sitio correcto según tu idioma.";
      if (detectedEl)
        detectedEl.textContent = isEn
          ? "Detected: English"
          : "Detectado: Español";

      if (window.location.pathname === "/") {
        window.location.replace(isEn ? "/en/" : "/es/");
      }
    })();
  </script>
</Layout>
